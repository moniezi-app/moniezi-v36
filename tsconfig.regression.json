{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": ".tmp/regression-tests",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2020",
    "lib": [
      "ES2020",
      "DOM"
    ],
    "types": [
      "node"
    ],
    "jsx": "react-jsx",
    "sourceMap": false,
    "declaration": false,
    "declarationMap": false,
    "incremental": false,
    "allowImportingTsExtensions": false
  },
  "include": [
    "types.ts",
    "src/features/mileage/draft.ts",
    "src/navigation/hashRouting.ts",
    "src/features/equity/fundingMetrics.ts",
    "tests/regression/**/*.ts"
  ]
}
