{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "moniezi-license",
  "main": "src/index.js",
  "compatibility_date": "2026-07-22",
  "vars": {
    "ALLOWED_ORIGIN": "https://YOUR-MONIEZI-APP-ORIGIN.example",
    "MAX_DEVICES": "3",
    "GUMROAD_PRODUCT_ID": "REPLACE_WITH_GUMROAD_PRODUCT_ID"
  },
  "kv_namespaces": [
    {
      "binding": "LICENSE_BINDINGS",
      "id": "REPLACE_WITH_KV_NAMESPACE_ID"
    }
  ]
}
